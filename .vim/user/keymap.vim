let mapleader = " "
inoremap jk <ESC>


nnoremap <leader>q :q!<CR>
nnoremap <leader>w :w!<CR>
nnoremap <leader>i :PlugInstall<CR>

" WhichKey
nnoremap <silent> <leader> :<c-u>WhichKey '<Space>'<CR>

" NERDTree
nnoremap <leader>e :NERDTreeToggle<CR> 

nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l


